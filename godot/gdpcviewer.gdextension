[configuration]
entry_symbol = "native_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
windows.x86_64 = "res://../install/bin/gdpcviewer.dll"
linux.x86_64   = "res://../install/lib/libgdpcviewer.so"
macos.arm64    = "res://../install/lib/libgdpcviewer.dylib"
ios.arm64      = "res://../install/lib/libgdpcviewer.a"
